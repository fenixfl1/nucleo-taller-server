{
  "name": "nucleo-taller-server",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node -r tsconfig-paths/register src/index.ts",
    "build": "ts-node scripts/esbuild.ts",
    "prebuild": "node scripts/build.ts",
    "test": "jest --config jest.config.ts",
    "test:watch": "npm run test -- --watch",
    "test:coverage": "npm run test -- --coverage",
    "start": "node build/app.cjs",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 startOrReload ecosystem.config.cjs --env production",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "typeorm": "node --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration": "npm run typeorm -- migration:generate -d src/data-source.ts src/migrations/migration",
    "migration:create": "npm run typeorm -- migration:create src/migrations/PostRefactoring",
    "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
    "migration:fake": "npm run typeorm -- migration:run -d src/data-source.ts --fake",
    "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
    "seed:admin": "node --require ts-node/register --require tsconfig-paths/register src/seeds/bootstrap-admin.seed.ts",
    "seed:excel": "node --require ts-node/register --require tsconfig-paths/register src/seeds/import-excel.seed.ts",
    "seed:operational": "node --require ts-node/register --require tsconfig-paths/register src/seeds/operational.seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cookie-parse": "^0.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cryp": "^0.1.1",
    "crypto": "^1.0.1",
    "esbuild": "^0.27.3",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "nodemailer": "^8.0.1",
    "nodemon": "^3.1.14",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
